# ---- apps/api (microservicio Fastify) ----
PORT=3001
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
INTERNAL_API_KEY=change-me-shared-between-front-and-back

# Origen(es) permitidos para CORS. El front vive en el repo landingGoTom.
# Acepta lista separada por comas: "http://localhost:3000,https://gotom.app"
CORS_ORIGIN=http://localhost:3000

# ---- Front (landingGoTom) ----
# El front consume este micro vía HTTP+JSON. Estas variables se setean en
# landingGoTom/.env.local (no acá). Las dejamos como referencia:
#   API_BASE_URL=http://localhost:3001
#   INTERNAL_API_KEY=<igual al de arriba>
