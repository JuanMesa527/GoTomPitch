# ─── modo dev (sin Supabase ni DeepSeek) ───────────────────────────────
# Con MOCK_MODE=true:
#   - Repo se monta en memoria (datos volátiles, se pierden al reiniciar)
#   - LLM devuelve cards canned con delay artificial (simula streaming)
#   - DEEPSEEK_API_KEY / SUPABASE_* NO son requeridas
#   - Se habilita el endpoint extra POST /dev/sessions/sample
MOCK_MODE=true
MOCK_LLM_DELAY_MS=350

# ─── infra compartida ──────────────────────────────────────────────────
PORT=3001
INTERNAL_API_KEY=change-me-shared-between-front-and-back
CORS_ORIGIN=http://localhost:3000

# ─── modo real (MOCK_MODE=false) ───────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
